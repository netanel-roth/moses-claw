

#!/usr/bin/env python3
import json, sys, urllib.request, base64

def get_token():
    req = urllib.request.Request(
        "http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token",
        headers={"Metadata-Flavor": "Google"})
    with urllib.request.urlopen(req, timeout=5) as r:
        return json.load(r)["access_token"]

def get_secret(secret_id, token):
    url = f"https://secretmanager.googleapis.com/v1/projects/moses-claw/secrets/{secret_id}/versions/latest:access"
    req = urllib.request.Request(url, headers={"Authorization": f"Bearer {token}"})
    with urllib.request.urlopen(req, timeout=5) as r:
        data = json.load(r)
        return base64.b64decode(data["payload"]["data"]).decode()

try:
    request = json.load(sys.stdin)
    ids = request.get("ids", [])
    token = get_token()
    values = {}
    errors = {}
    for secret_id in ids:
        try:
            values[secret_id] = get_secret(secret_id, token)
        except Exception as e:
            errors[secret_id] = {"message": str(e)}
    json.dump({"protocolVersion": 1, "values": values, "errors": errors}, sys.stdout)
except Exception as e:
    json.dump({"protocolVersion": 1, "values": {}, "errors": {"_global": {"message": str(e)}}}, sys.stdout)
