        "sandbox": {
          "mode": "all",
          "backend": "docker",
          "workspaceAccess": "rw",
          "scope": "session"
        },
        "tools": {
          "allow": [
            "exec",
            "read",
            "write",
            "edit",
            "apply_patch",
            "memory_search",
            "memory_get",
            "web_fetch",
            "browser",
            "cron",
            "message"
          ],
          "deny": [
            "elevated",
            "gateway",
            "sessions_spawn",
            "whatsapp_login"
