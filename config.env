# ─────────────────────────────────────────────────
# OpenClaw GCP — Configure once, deploy many
# ─────────────────────────────────────────────────

# GCP project (must already exist with billing enabled)
GCP_PROJECT="my-gcp-project"

# VM settings
VM_NAME="openclaw-gateway"
ZONE="us-central1-a"
MACHINE_TYPE="e2-medium"      # e2-small ($12/mo) minimum; e2-medium ($25/mo) for reliable builds
BOOT_DISK_SIZE="20GB"
IMAGE_FAMILY="debian-12"
IMAGE_PROJECT="debian-cloud"

# Security: SSH access
# "iap" (recommended) — SSH only via IAP tunnel (gcloud compute ssh). Blocks direct internet SSH.
# "open" — allows SSH from 0.0.0.0/0 (default GCP behavior, less secure)
SSH_ACCESS="iap"

# Security: monthly budget alert (USD). Set to "" to skip.
BUDGET_AMOUNT="25"

# OpenClaw Gateway
GATEWAY_PORT="18789"
GATEWAY_TOKEN=""              # leave empty to auto-generate on deploy
GOG_KEYRING_PASSWORD=""       # leave empty to auto-generate on deploy

# OpenClaw repo (change if using a fork)
OPENCLAW_REPO="https://github.com/openclaw/openclaw.git"
OPENCLAW_BRANCH="main"

# Extra binaries to bake into the Docker image (space-separated URLs to .tar.gz archives)
# Each archive is extracted to /usr/local/bin inside the container.
# The defaults below match the guide's examples. Remove or add as needed.
EXTRA_BINARY_URLS=""
